# Base URL the client uses for API requests.
# In dev keep as "/api" (Vite proxies to VITE_API_PROXY_TARGET).
# In prod set to your deployed backend, e.g. "https://your-api.example.com/api".
VITE_API_BASE_URL=/api

# Only used by the Vite dev server proxy (development only)
VITE_API_PROXY_TARGET=http://localhost:5000
