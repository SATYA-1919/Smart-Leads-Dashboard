# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Local Mongo:  mongodb://localhost:27017/smart_leads
# Docker:       mongodb://mongo:27017/smart_leads
# Atlas:        mongodb+srv://<user>:<pass>@<cluster>/smart_leads
MONGO_URI=mongodb://localhost:27017/smart_leads

# ─── JWT ──────────────────────────────────────────────────
# IMPORTANT: replace with a long, random secret in production (>= 32 chars)
JWT_SECRET=replace_me_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
